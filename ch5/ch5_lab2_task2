#Making functions

def greet(name, greeting):  
    if greeting == "" or greeting.isspace():                #if the greeting is empty
        greeting = "Hello"
    return f"{greeting}, {name}!"

def main():
    name = input("Enter your name: ")
    greeting = input("Enter a greeting or press enter: ")
    print(greet(name, greeting))

main()