from random import random, randint 

n = int(input("How many times do you want to throw the dice?: "))

for i in range(1, n + 1):
    dice1 = randint(1,6) 
    dice2 = randint(1,6)    
    print(f"Roll {i}: Dice 1 = {dice1}, Dice 2 = {dice2}, Total = {dice1 + dice2}")